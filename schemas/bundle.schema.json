{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://effortlessmetrics.dev/schemas/evidencebus/bundle.schema.json",
  "title": "EvidenceBus Bundle",
  "type": "object",
  "required": [
    "eb_version",
    "bundle_id",
    "created_at",
    "manifest",
    "summary"
  ],
  "properties": {
    "eb_version": {
      "type": "string"
    },
    "bundle_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "manifest": {
      "type": "object",
      "required": [
        "packets",
        "artifacts",
        "integrity"
      ],
      "properties": {
        "packets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "packet_id",
              "relative_path",
              "sha256"
            ],
            "properties": {
              "packet_id": {
                "type": "string"
              },
              "relative_path": {
                "type": "string"
              },
              "sha256": {
                "type": "string"
              }
            }
          }
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "packet_id",
              "relative_path",
              "role",
              "sha256"
            ],
            "properties": {
              "packet_id": {
                "type": "string"
              },
              "relative_path": {
                "type": "string"
              },
              "role": {
                "type": "string",
                "enum": [
                  "native_payload",
                  "report_html",
                  "stdout_log",
                  "stderr_log",
                  "plain_text",
                  "arbitrary_binary"
                ]
              },
              "sha256": {
                "type": "string"
              }
            }
          }
        },
        "integrity": {
          "type": "object",
          "required": [
            "manifest_digest",
            "packet_digests",
            "artifact_digests"
          ],
          "properties": {
            "manifest_digest": {
              "type": "string"
            },
            "packet_digests": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "artifact_digests": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "total_packets",
        "total_artifacts",
        "status_counts",
        "severity_counts"
      ],
      "properties": {
        "total_packets": {
          "type": "integer",
          "minimum": 0
        },
        "total_artifacts": {
          "type": "integer",
          "minimum": 0
        },
        "status_counts": {
          "type": "object",
          "required": [
            "pass",
            "fail",
            "warn",
            "indeterminate",
            "error"
          ],
          "properties": {
            "pass": {
              "type": "integer",
              "minimum": 0
            },
            "fail": {
              "type": "integer",
              "minimum": 0
            },
            "warn": {
              "type": "integer",
              "minimum": 0
            },
            "indeterminate": {
              "type": "integer",
              "minimum": 0
            },
            "error": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "severity_counts": {
          "type": "object",
          "required": [
            "note",
            "warning",
            "error"
          ],
          "properties": {
            "note": {
              "type": "integer",
              "minimum": 0
            },
            "warning": {
              "type": "integer",
              "minimum": 0
            },
            "error": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    }
  }
}
